#!/bin/sh

  for battery in /sys/class/power_supply/BAT?*; do
    status=$(cat "$battery/status" 2>/dev/null)
    capacity=$(cat "$battery/capacity" 2>/dev/null)

    case "$status" in
      "Full")         icon="´ôí" ;;        # Full
      "Charging")     icon="´ê×" ;;        # Charging
      "Discharging")  icon="¾▒ÖÑ" ;;        # Discharging
      "Not charging") icon="¾░ØÖ" ;;        # Not Charging
      "Unknown")      icon="¯¢Å" ;;        # Unknown
      *)              icon="?" ;;
    esac

    warn=""
    [ "$status" = "Discharging" ] && [ "$capacity" -le 25 ] && warn="ÔØù"
  done

    echo " $icon $warn$capacity%"
