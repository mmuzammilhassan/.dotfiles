#!/bin/sh

BREEZE_TEMPLATE="laravel-master-breeze"
PLAIN_TEMPLATE="laravel-no-breeze"

if [ -z "$1" ] || [ -z "$2" ]; then
    echo "Usage: ./make-laravel.sh [project-name] [type]"
    echo "Types: breeze | plain"
    exit 1
fi

NEW_PROJECT=$1
TYPE=$2

if [ "$TYPE" == "breeze" ]; then
    SOURCE=$BREEZE_TEMPLATE
elif [ "$TYPE" == "plain" ]; then
    SOURCE=$PLAIN_TEMPLATE
else
    echo "Error: Use 'breeze' or 'plain'."
    exit 1
fi

echo "   Creating $NEW_PROJECT..."
cp -r "$SOURCE" "$NEW_PROJECT"
cd "$PROJECT_NAME" || exit

# --- THE GIT FIX ---
# Remove the template's Git history and start fresh
# rm -rf .git
git init
# -------------------

ddev config --project-name="$NEW_PROJECT"

cp .env.example .env
sed -i "s/APP_NAME=Laravel/APP_NAME=$NEW_PROJECT/g" .env

ddev start
ddev exec php artisan key:generate

# Final Git Commit (Optional but recommended)
git add .
git commit -m "Initial commit from $TYPE template"

echo "----------------------------------------------------"
echo "   Project Ready with Fresh Git History"
echo "   URL: https://$NEW_PROJECT.ddev.site"
echo "----------------------------------------------------"
