#!/bin/bash

# 1. Get project name
if [ -z "$1" ]; then
    read -p "Enter Project Name: " PROJECT_NAME
else
    PROJECT_NAME=$1
fi

if [ -z "$PROJECT_NAME" ]; then
    echo "Error: Project name is required."
    exit 1
fi

# 2. Ask about TALL Stack (Breeze)
echo "----------------------------------------------"
echo "Would you like to install the TALL Stack (Breeze with Livewire/Alpine)?"
read -p "[y/N]: " INSTALL_BREEZE
echo "----------------------------------------------"

# 3. Create directory & DDEV
mkdir "$PROJECT_NAME"
cd "$PROJECT_NAME"

echo "Initializing DDEV..."
# We remove --create-docroot so DDEV doesn't make an empty public folder that conflicts with Laravel
ddev config --project-type=laravel --docroot=public 
ddev start

# 4. Install Laravel Framework
echo "Downloading Laravel..."
# FIX: We install to 'tmp' because the current folder contains .ddev, 
# and Composer refuses to install into a non-empty directory.
ddev composer create-project --prefer-dist laravel/laravel tmp

# Move files from tmp to root and remove tmp
ddev exec "rsync -a tmp/ ./ && rm -rf tmp"

# 5. Install TALL Stack (If requested)
if [[ "$INSTALL_BREEZE" =~ ^[Yy]$ ]]; then
    echo "Installing Breeze (TALL Stack)..."
    ddev composer require laravel/breeze --dev
    echo "This installs Breeze with Livewire (Tailwind + Alpine + Livewire)"
    ddev artisan breeze:install livewire --dark
else
    echo "Skipping Starter Kit..."
fi

# 6. Install Dev Tools
echo "Installing Neovim Helpers & Debugbar..."
ddev composer require --dev barryvdh/laravel-ide-helper barryvdh/laravel-debugbar

# Generate Helpers
ddev artisan ide-helper:generate || true
ddev artisan ide-helper:meta || true
ddev artisan ide-helper:models -N || true

# 7. Git Setup
if [ ! -d ".git" ]; then
    git init
    git add .
    git commit -m "Initial commit"
fi

# 8. Finalize
echo "----------------------------------------------"
echo "Project '$PROJECT_NAME' is ready!"
echo "Url: https://$PROJECT_NAME.ddev.site"
echo "----------------------------------------------"

ddev launch
