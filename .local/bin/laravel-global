#!/bin/sh

# 1. Get project name
if [ -z "$1" ]; then
    printf "Enter Project Name: "
    read PROJECT_NAME
else
    PROJECT_NAME=$1
fi

if [ -z "$PROJECT_NAME" ]; then
    echo "Error: Project name is required."
    exit 1
fi

# 2. Run Global Installer
# This is interactive! It will ask you:
# - Which Starter Kit? (Breeze/Jetstream)
# - Which Database? (Choose SQLite since you use sqlitebrowser)
echo "----------------------------------------------"
echo "Running Laravel Global Installer..."
echo "----------------------------------------------"

laravel new "$PROJECT_NAME"

# Check if it actually worked
if [ ! -d "$PROJECT_NAME" ]; then
    echo "Error: Directory not found. Did the installer fail?"
    exit 1
fi

# 3. Enter Directory
cd "$PROJECT_NAME" || exit

# 4. Configure DDEV (Optimized for SQLite)
echo "----------------------------------------------"
echo "Initializing DDEV..."
# We use --omit-containers=db because you chose SQLite in the installer
ddev config --project-type=laravel --docroot=public --omit-containers=db
ddev start

# 5. Install Neovim Helpers (The "Zephyr Special")
echo "----------------------------------------------"
echo "Installing Neovim Helpers & Debugbar..."
ddev composer require --dev barryvdh/laravel-ide-helper barryvdh/laravel-debugbar

# Generate Helper Files
ddev artisan ide-helper:generate || true
ddev artisan ide-helper:meta || true
ddev artisan ide-helper:models -N || true

# 6. Launch
echo "----------------------------------------------"
echo "Project '$PROJECT_NAME' is ready!"
echo "Url: https://$PROJECT_NAME.ddev.site"
echo "----------------------------------------------"

ddev launch

# 7. Stay in Directory
exec "$SHELL"
