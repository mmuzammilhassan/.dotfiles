+    /* Persistent block handling */
+    if (pblocks[block - blocks].persist == 1 && pblocks[block - blocks].pid > 0) {
+        /* persistent process already running — do nothing */
+        return;
+    }
+
+    /* If block is persistent, start it and read its stdout asynchronously */
+    if (pblocks[block - blocks].persist == 1) {
+        int pipefd[2];
+        pipe(pipefd);
+
+        int pid = fork();
+        if (pid == 0) {
+            /* Child: hook stdout to pipe */
+            close(pipefd[0]);
+            dup2(pipefd[1], STDOUT_FILENO);
+            execl("/bin/sh", "sh", "-c", block->command, NULL);
+            exit(0);
+        }
+
+        /* Parent */
+        pblocks[block - blocks].pid = pid;
+        close(pipefd[1]);
+
+        /* Non-blocking read for streaming output */
+        fcntl(pipefd[0], F_SETFL, O_NONBLOCK);
+
+        /* read initial output */
+        read(pipefd[0], output, CMDLENGTH);
+        return;
+    }
+
     if (!cmdf)
         return;
     fgets(output, CMDLENGTH, cmdf);
     pclose(cmdf);
 }
